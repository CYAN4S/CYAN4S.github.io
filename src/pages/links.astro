---
import Icon from "../components/Icon.astro";
import Default from "../layouts/Default.astro";
import bgImage from "../assets/bio-bg.jpg";
import profileImage from "../assets/profile.png";

const activeLinks = [
  {
    name: "X (Twitter)",
    id: "@cyan4s",
    url: "https://x.com/cyan4s",
    icon: "twitter",
    fill: "000000",
    hoverText: "group-hover:text-black",
  },
  {
    name: "GitHub",
    id: "CYAN4S",
    url: "https://github.com/CYAN4S",
    icon: "github",
    fill: "181717",
    hoverText: "group-hover:text-[#181717]",
  },
  {
    name: "Instagram",
    id: "cyan4s",
    url: "https://instagram.com/cyan4s",
    icon: "instagram",
    fill: "E4405F",
    hoverText: "group-hover:text-[#E4405F]",
  },
  {
    name: "SoundCloud",
    id: "cyan4s",
    url: "https://soundcloud.com/cyan4s",
    icon: "soundcloud",
    fill: "FF3300",
    hoverText: "group-hover:text-[#FF3300]",
  },
  {
    name: "Dribbble",
    id: "cyan4s",
    url: "https://dribbble.com/cyan4s",
    icon: "dribbble",
    fill: "EA4C89",
    hoverText: "group-hover:text-[#EA4C89]",
  },
  {
    name: "Pixiv",
    id: "15130363",
    url: "https://www.pixiv.net/users/15130363",
    icon: "pixiv",
    fill: "0096FA",
    hoverText: "group-hover:text-[#0096FA]",
  },
  {
    name: "Steam",
    id: "cyan4s",
    url: "https://steamcommunity.com/id/cyan4s",
    icon: "steam",
    fill: "000000",
    hoverText: "group-hover:text-black",
  },
  {
    name: "Unsplash",
    id: "@cyan4s",
    url: "https://unsplash.com/@cyan4s",
    icon: "unsplash",
    fill: "000000",
    hoverText: "group-hover:text-black",
  },
  {
    name: "LinkedIn",
    id: "cyan4s",
    url: "https://linkedin.com/in/cyan4s",
    icon: "linkedin",
    fill: "000000",
    hoverText: "group-hover:text-[#000000]",
  },
  {
    name: "Email",
    id: "me@cyan4s.com",
    url: "mailto:me@cyan4s.com",
    icon: "email",
    fill: "26bfb3",
    hoverText: "group-hover:text-primary",
  },
];

const inactiveLinks = [
  {
    name: "Bluesky",
    url: "https://bsky.app/profile/cyan4s.com",
    icon: "bluesky",
    fill: "0285FF",
    hoverText: "group-hover:text-[#0285FF]",
  },
  { name: "Behance", url: "https://www.behance.net/cyan4s", icon: "behance" },
  { name: "Pinterest", url: "https://pinterest.com/cyan4s", icon: "pinterest" },
  { name: "Vimeo", url: "https://vimeo.com/cyan4s", icon: "vimeo" },
];
---

<Default title="Links | CYAN4S">
  <!-- Background Image -->
  <div
    class="fixed inset-0 -z-10 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${bgImage.src}');`}
  >
  </div>

  <section
    class="relative mx-auto flex min-h-lvh max-w-2xl flex-col items-center justify-center px-4 pt-16 pb-24 sm:py-32"
  >
    <!-- Profile -->
    <div class="mb-10 flex flex-col items-center text-center">
      <div
        class="shadow-common mb-5 flex h-48 w-48 items-center justify-center overflow-hidden rounded-full border border-white/40 backdrop-blur-xl transition-transform duration-500 hover:scale-105 hover:rotate-3"
      >
        <img
          src={profileImage.src}
          alt="CYAN4S"
          class="h-full w-full object-cover"
        />
      </div>
      <h1
        class="font-display mb-2 text-3xl font-extrabold text-primary text-shadow-[0_2px_6px_#f5f5f5,0_1px_2px_#f5f5f5]"
      >
        CYAN4S
      </h1>
      <p class="font-medium text-gray-500">모두를 위한 게임 크리에이터</p>
    </div>

    <!-- Active Links -->
    <div class="flex w-full flex-col gap-4">
      {
        activeLinks.map((link) => (
          <div class="group relative">
            <a
              href={link.url}
              class={`shadow-common relative flex items-center overflow-hidden rounded-full border border-white/40 bg-white p-4 backdrop-blur-xl transition-all duration-300 ease-out group-hover:-translate-y-1`}
            >
              <div class="relative flex h-14 w-14 shrink-0 items-center justify-center transition-transform duration-300 group-hover:scale-110">
                <Icon id={link.icon} size={32} fill={link.fill} />
              </div>

              <div class="relative z-10 ml-4 flex flex-col">
                <span
                  class={`text-xl font-bold text-gray-700 transition-colors duration-300 ${link.hoverText}`}
                >
                  {link.name}
                </span>
                <span class="text-sm text-gray-400">{link.id}</span>
              </div>

              <div class="relative z-10 ml-auto mr-2 -translate-x-2.5 text-gray-300 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:text-gray-400 group-hover:opacity-100">
                <Icon id="link" size={24} fill="cbd5e1" />
              </div>
            </a>
          </div>
        ))
      }
    </div>

    <!-- Inactive Links -->
    <div
      class="mt-20 flex w-full flex-col items-center border-t border-gray-200/50 pt-8"
    >
      <h2
        class="mb-2 text-xs font-bold uppercase tracking-widest text-gray-400"
      >
        미운영 계정
      </h2>
      <div class="flex flex-wrap justify-center gap-3">
        {
          inactiveLinks.map((link) => (
            <div class="group">
              <a
                href={link.url}
                class="flex items-center gap-2 rounded-xl border border-white/40 bg-white px-4 py-2 text-sm font-semibold text-gray-500 shadow-common backdrop-blur-md transition-all duration-300 group-hover:scale-105 group-hover:bg-white/90 group-hover:text-gray-800"
              >
                <div class="opacity-60 transition-opacity group-hover:opacity-100">
                  <Icon id={link.icon} size={16} fill="9ca3af" />
                </div>
                {link.name}
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Default>
