---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import Default from "./Default.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import { Image } from "astro:assets";

type Props = CollectionEntry<"blog">["data"] & {
  post: CollectionEntry<"blog">;
  prev: CollectionEntry<"blog">;
  next: CollectionEntry<"blog">;
};

const {
  post: {
    data: { title, description, pubDate, updatedDate, heroImage },
    id,
  },
  prev,
  next,
} = Astro.props;
---

<Default title={title} description={description} heroImage={heroImage}>
  <article class="prose max-w-3xl mx-auto 
  p-4 pt-8 pb-8 
  prose-a:text-primary prose-a:decoration-dotted
  prose-headings:text-gray-700
  prose-code:font-normal prose-code:bg-yellow-50 [&_pre_code]:bg-transparent
  ">
    <div>
      {
        heroImage && (
          <Image
            src={heroImage}
            alt={`게시글 '${title}'의 헤더 이미지`}
            loading="eager"
          />
        )
      }
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="text-end text-gray-500 font-bold mt-2 mb-8">
        <FormattedDate date={pubDate} />
        {
          updatedDate && (
            <>
              <br />
              <span class="italic">
                <FormattedDate date={updatedDate} />에 수정됨
              </span>
            </>
          )
        }
      </div>
    </div>
    <hr />
    <slot />
  </article>

  <div class="mx-auto mb-16 grid sm:grid-cols-2 grid-cols-1 gap-6 p-4 max-w-3xl">
    <div>
      <p class="mb-4"><strong>이전 게시글</strong></p>
      {
        prev ? (
          <a class="flex flex-col h-60 border border-gray-200 rounded-xl overflow-hidden no-underline shadow-[0px_8px_8px_-8px_#0001] transition-shadow duration-200 hover:shadow-[0px_8px_16px_-8px_#00b8a970]" href={`/blog/${prev.id}`}>
            <div class="px-6 pt-5 text-[#444] text-[1.4rem] font-semibold">{prev.data.title}</div>
            <div class="px-6 pt-3 text-[#333] text-base font-normal">{prev.data.description}</div>
            <div class="px-6 py-2 text-[0.9rem] font-extrabold text-[#888] text-end">
              <FormattedDate date={prev.data.pubDate} />
            </div>
          </a>
        ) : (
          <div class="flex h-60 border border-gray-200 bg-black/2 border-dotted rounded-xl justify-center items-center">
            <span class="text-gray-500">첫 게시글입니다.</span>
          </div>
        )
      }
    </div>
    <div>
      <p class="mb-4"><strong>다음 게시글</strong></p>
      {
        next ? (
          <a class="flex flex-col h-60 border border-gray-200 rounded-xl overflow-hidden no-underline shadow-[0px_8px_8px_-8px_#0001] transition-shadow duration-200 hover:shadow-[0px_8px_16px_-8px_#00b8a970]" href={`/blog/${next.id}`}>
            <div class="px-6 pt-5 text-[#444] text-[1.4rem] font-semibold">{next.data.title}</div>
            <div class="px-6 pt-3 text-[#333] text-base font-normal">{next.data.description}</div>
            <div class="px-6 py-2 text-[0.9rem] font-extrabold text-[#888] text-end">
              <FormattedDate date={next.data.pubDate} />
            </div>
          </a>
        ) : (
          <div class="flex h-60 border border-gray-200 bg-black/2 border-dotted rounded-xl justify-center items-center">
            <span class="text-gray-500">마지막 게시글입니다.</span>
          </div>
        )
      }
    </div>
  </div>
  <ScrollToTop />
</Default>
