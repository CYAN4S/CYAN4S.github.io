---
import HeaderLink from "./HeaderLink.astro";
import Icon from "./Icon.astro";
---

<!-- 모바일 메뉴 토글 체크박스 (JS 제거용) -->
<input type="checkbox" id="menu-toggle" class="peer hidden" />

<header
    id="main-header"
    class="font-display fixed flex justify-between gap-4 text-primary z-10 left-0 right-0 top-0 px-6 backdrop-blur-sm bg-white/30 h-20 items-center transition-all duration-400 ease-out border border-transparent [&.scrolled]:top-4 [&.scrolled]:left-4 [&.scrolled]:right-4 [&.scrolled]:rounded-[40px] [&.scrolled]:border-white/40 [&.scrolled]:bg-linear-to-b [&.scrolled]:from-white/95 [&.scrolled]:to-white/75 [&.scrolled]:shadow-common"
>
    <a
        href="/"
        id="cyan4s"
        class="flex items-center gap-3 text-2xl font-extrabold text-primary no-underline"
    >
        <Icon id="cyan4s" />CYAN4S
    </a>

    <!-- 데스크탑용 (sm 이상에서 보임) -->
    <nav class="hidden items-center gap-4 sm:flex">
        <HeaderLink href="/blog">Blog</HeaderLink>
        <!-- <HeaderLink href="/portfolio">Portfolio</HeaderLink> -->
        <HeaderLink href="/links">Links</HeaderLink>
    </nav>

    <nav class="flex items-center justify-center gap-4 *:h-6 *:w-6">
        <a href="https://x.com/cyan4s" aria-label="CYAN4S' X">
            <Icon id="twitter" />
        </a>
        <a href="https://github.com/CYAN4S" aria-label="CYAN4S' GitHub">
            <Icon id="github" />
        </a>
        <label for="menu-toggle" class="cursor-pointer sm:hidden">
            <Icon id="menu" />
        </label>
    </nav>
</header>

<!-- 모바일용 (sm 미만에서 보임, 체크박스 상태에 따라 위치 변경) -->
<nav
    id="mobile-menu"
    class="font-display text-primary fixed -right-30 top-25 z-20 flex flex-col items-center gap-4 rounded-2xl border border-white/40 bg-white/80 p-4 shadow-common backdrop-blur-3xl transition-all ease-in-out duration-200 peer-checked:right-4 [&.scrolled]:top-28 sm:hidden"
>
    <HeaderLink href="/blog">Blog</HeaderLink>
    <!-- <HeaderLink href="/portfolio">Portfolio</HeaderLink> -->
    <HeaderLink href="/links">Links</HeaderLink>
</nav>

<script>
    const header = document.getElementById("main-header");
    const mobileMenu = document.getElementById("mobile-menu");
    const onScroll = () => {
        if (window.scrollY > 0) {
            header?.classList.add("scrolled");
            mobileMenu?.classList.add("scrolled");
        } else {
            header?.classList.remove("scrolled");
            mobileMenu?.classList.remove("scrolled");
        }
    };
    window.addEventListener("scroll", onScroll);
    onScroll();
</script>
