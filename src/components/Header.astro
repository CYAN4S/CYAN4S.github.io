---
import HeaderLink from "./HeaderLink.astro";
import Icon from "./Icon.astro";
---

<header
  class="font-display fixed top-0 z-10 flex h-20 w-full items-center justify-between gap-4 bg-white/80 px-6 text-primary backdrop-blur-lg"
>
  <a
    href="/"
    id="cyan4s"
    class="flex items-center gap-4 text-2xl font-extrabold text-primary no-underline"
  >
    <Icon id="cyan4s" />CYAN4S
  </a>

  <!-- 데스크탑용 (sm 이상에서 보임) -->
  <nav class="hidden items-center gap-4 sm:flex">
    <HeaderLink href="/blog">Blog</HeaderLink>
    <HeaderLink href="/portfolio">Portfolio</HeaderLink>
  </nav>

  <!-- 모바일 메뉴 토글 체크박스 (JS 제거용) -->
  <input type="checkbox" id="menu-toggle" class="peer hidden" />

  <!-- 모바일용 (sm 미만에서 보임, 체크박스 상태에 따라 위치 변경) -->
  <nav
    id="h-1"
    class="fixed -right-26 top-25 flex flex-col items-center gap-4 rounded-2xl border border-white/50 bg-white/80 p-4 shadow backdrop-blur-lg transition-[right] duration-200 peer-checked:right-4 sm:hidden"
  >
    <HeaderLink href="/blog">Blog</HeaderLink>
    <HeaderLink href="/portfolio">Portfolio</HeaderLink>
  </nav>

  <nav class="flex items-center justify-center gap-4 *:h-6 *:w-6">
    <a href="https://github.com/CYAN4S" aria-label="CYAN4S' GitHub">
      <Icon id="github" />
    </a>
    <a href="https://x.com/cyan4s" aria-label="CYAN4S' X">
      <Icon id="twitter" />
    </a>
    <a href="https://bio.cyan4s.com" aria-label="CYAN4S' Link in bio page">
      <Icon id="link" />
    </a>
    <label for="menu-toggle" class="cursor-pointer sm:hidden">
      <Icon id="menu" />
    </label>
  </nav>
</header>
